# ─────────────────────────────────────────────────────────────────
# NIA Platform — Environment Variables Example
# Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=DEBUG
JSON_LOGS=false

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://nia_user:nia_secret@postgres:5432/nia_dev

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Vector DB ────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Security ─────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Model Provider ───────────────────────────────────────────────
# Opciones: lmstudio | vertexai | openai
MODEL_PROVIDER=lmstudio

# LM Studio (local, API nativa v1 — LM Studio >= 0.4.0)
# La URL apunta a la raíz, sin /v1. El provider usa /api/v1/chat internamente.
LM_STUDIO_BASE_URL=http://host.docker.internal:1234
LM_STUDIO_CHAT_MODEL=google/gemma-4-e4b
LM_STUDIO_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5-GGUF

# Vertex AI (producción)
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_CHAT_MODEL=gemini-1.5-flash-001
VERTEX_AI_PRO_MODEL=gemini-1.5-pro-001
VERTEX_AI_EMBED_MODEL=text-multilingual-embedding-002
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/sa-key.json

# OpenAI (opcional fallback)
OPENAI_API_KEY=sk-...

# ── Internal Service URLs ─────────────────────────────────────────
MODEL_ADAPTER_URL=http://model-adapter:8005
TENANT_MANAGER_URL=http://tenant-manager:8003
RAG_SERVICE_URL=http://rag-service:8002
RECOMMENDER_URL=http://recommender:8004
CHECKOUT_URL=http://checkout:8006
HANDOFF_URL=http://handoff:8007
TRANSCRIPT_URL=http://transcript:8008
FALLBACK_URL=http://fallback:8009

# ── Teams Handoff ────────────────────────────────────────────────
# Para desarrollo, apunta al stub local
TEAMS_WEBHOOK_URL=http://teams-stub:3001/webhook
TEAMS_TIMEOUT_MINUTES=15
TEAMS_MAX_WAIT_MINUTES=5
TEAMS_BOT_APP_ID=00000000-0000-0000-0000-000000000000
TEAMS_BOT_APP_PASSWORD=CHANGE_ME

# ── Stripe (Checkout) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=clp

# ── Observability ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=

# ── Rate Limits ──────────────────────────────────────────────────
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_API_PER_MINUTE=100

# ── Semantic Cache ───────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600
