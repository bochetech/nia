{
  "info": {
    "name": "NIA - Neural Intelligence Assistant",
    "description": "Colección completa de APIs para el sistema NIA - todos los servicios con ejemplos y variables configuradas",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost",
      "description": "URL base para todos los servicios"
    },
    {
      "key": "orchestrator_port",
      "value": "8001",
      "description": "Puerto del servicio orchestrator"
    },
    {
      "key": "rag_port",
      "value": "8002",
      "description": "Puerto del servicio RAG"
    },
    {
      "key": "tenant_manager_port",
      "value": "8003",
      "description": "Puerto del tenant manager"
    },
    {
      "key": "recommender_port",
      "value": "8004",
      "description": "Puerto del servicio de recomendaciones"
    },
    {
      "key": "model_adapter_port",
      "value": "8005",
      "description": "Puerto del model adapter"
    },
    {
      "key": "checkout_port",
      "value": "8006",
      "description": "Puerto del servicio de checkout"
    },
    {
      "key": "handoff_port",
      "value": "8007",
      "description": "Puerto del servicio de handoff"
    },
    {
      "key": "transcript_port",
      "value": "8008",
      "description": "Puerto del servicio de transcript"
    },
    {
      "key": "fallback_port",
      "value": "8009",
      "description": "Puerto del servicio de fallback"
    },
    {
      "key": "demo_port",
      "value": "8080",
      "description": "Puerto del servidor demo"
    },
    {
      "key": "tenant_id",
      "value": "demo-tenant",
      "description": "ID del tenant de prueba"
    },
    {
      "key": "session_id",
      "value": "{{$randomUUID}}",
      "description": "ID de sesión generado automáticamente"
    },
    {
      "key": "auth_token",
      "value": "Bearer your-jwt-token-here",
      "description": "Token de autenticación JWT"
    },
    {
      "key": "admin_token",
      "value": "Bearer your-admin-token-here",
      "description": "Token de administrador"
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "description": "API Key para servicios"
    }
  ],
  "item": [
    {
      "name": "🎯 Orchestrator Service (8001)",
      "description": "Servicio central del sistema - Maneja el flujo de conversación y FSM",
      "item": [
        {
          "name": "Send Chat Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{orchestrator_port}}/v1/chat",
              "host": ["{{base_url}}"],
              "port": "{{orchestrator_port}}",
              "path": ["v1", "chat"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hola, estoy buscando actividades de turismo activo en Asturias\",\n  \"session_id\": \"{{session_id}}\",\n  \"user_id\": \"user-123\"\n}"
            },
            "description": "Envía un mensaje al sistema y obtiene respuesta procesada por la FSM"
          },
          "response": [
            {
              "name": "Chat Response Example",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"message\": \"Hola, estoy buscando actividades de turismo activo en Asturias\",\n  \"session_id\": \"session-123\",\n  \"user_id\": \"user-123\"\n}"
                },
                "url": {
                  "raw": "http://localhost:8001/v1/chat",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8001",
                  "path": ["v1", "chat"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"message\": \"¡Perfecto! Te ayudo a encontrar actividades de turismo activo en Asturias. Tenemos senderismo, canoas, escalada y más. ¿Qué tipo de actividad te interesa más?\",\n    \"session_id\": \"session-123\",\n    \"state\": \"gathering_preferences\",\n    \"recommendations\": []\n  }\n}"
            }
          ]
        },
        {
          "name": "Stream Chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{orchestrator_port}}/v1/chat/stream",
              "host": ["{{base_url}}"],
              "port": "{{orchestrator_port}}",
              "path": ["v1", "chat", "stream"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Me interesa el senderismo y actividades en la naturaleza\",\n  \"session_id\": \"{{session_id}}\",\n  \"user_id\": \"user-123\"\n}"
            },
            "description": "Chat con streaming SSE para respuestas en tiempo real"
          }
        },
        {
          "name": "Get Session State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{orchestrator_port}}/v1/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "port": "{{orchestrator_port}}",
              "path": ["v1", "sessions", "{{session_id}}"]
            },
            "description": "Obtiene el estado actual de una sesión de chat"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{orchestrator_port}}/health",
              "host": ["{{base_url}}"],
              "port": "{{orchestrator_port}}",
              "path": ["health"]
            },
            "description": "Verifica el estado de salud del orchestrator"
          }
        }
      ]
    },
    {
      "name": "📚 RAG Service (8002)",
      "description": "Servicio de Retrieval-Augmented Generation para base de conocimiento turística",
      "item": [
        {
          "name": "Query Knowledge Base",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{rag_port}}/v1/rag/query",
              "host": ["{{base_url}}"],
              "port": "{{rag_port}}",
              "path": ["v1", "rag", "query"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"actividades de senderismo en Asturias\",\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"collection_name\": \"tourism_knowledge\",\n  \"top_k\": 5,\n  \"min_score\": 0.7\n}"
            },
            "description": "Busca información relevante en la base de conocimiento"
          },
          "response": [
            {
              "name": "Query Response Example",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"actividades de senderismo en Asturias\",\n  \"tenant_id\": \"demo-tenant\",\n  \"collection_name\": \"tourism_knowledge\",\n  \"top_k\": 5\n}"
                },
                "url": {
                  "raw": "http://localhost:8002/v1/rag/query",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8002",
                  "path": ["v1", "rag", "query"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"chunks\": [\n      {\n        \"content\": \"Senderismo en los Picos de Europa - Ruta del Cares\",\n        \"score\": 0.92,\n        \"source\": {\n          \"document_id\": \"doc-123\",\n          \"title\": \"Rutas de Senderismo Asturias\",\n          \"chunk_id\": \"chunk-456\"\n        }\n      }\n    ],\n    \"query_embedding_time_ms\": 45,\n    \"search_time_ms\": 12\n  }\n}"
            }
          ]
        },
        {
          "name": "Ingest Document",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{rag_port}}/v1/rag/ingest",
              "host": ["{{base_url}}"],
              "port": "{{rag_port}}",
              "path": ["v1", "rag", "ingest"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "tenant_id",
                  "value": "{{tenant_id}}",
                  "type": "text"
                },
                {
                  "key": "collection_name",
                  "value": "tourism_knowledge",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "description": "Ingesta un documento PDF/texto en la base de conocimiento"
          }
        },
        {
          "name": "Ingest JSON Knowledge",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{rag_port}}/v1/rag/ingest-json",
              "host": ["{{base_url}}"],
              "port": "{{rag_port}}",
              "path": ["v1", "rag", "ingest-json"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "tenant_id",
                  "value": "{{tenant_id}}",
                  "type": "text"
                },
                {
                  "key": "collection_name",
                  "value": "tourism_knowledge",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "description": "Ingesta un archivo JSON con actividades turísticas estructuradas"
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{rag_port}}/v1/rag/documents/doc-123",
              "host": ["{{base_url}}"],
              "port": "{{rag_port}}",
              "path": ["v1", "rag", "documents", "doc-123"]
            },
            "description": "Elimina un documento de la base de conocimiento"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{rag_port}}/health",
              "host": ["{{base_url}}"],
              "port": "{{rag_port}}",
              "path": ["health"]
            },
            "description": "Verifica el estado de salud del RAG service"
          }
        }
      ]
    },
    {
      "name": "👥 Tenant Manager (8003)",
      "description": "Gestión de tenants, configuración multi-tenant y autenticación",
      "item": [
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/api/tenants",
              "host": ["{{base_url}}"],
              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Turismo Asturias\",\n  \"domain\": \"asturias.com\",\n  \"config\": {\n    \"ai_config\": {\n      \"model\": \"gpt-4\",\n      \"temperature\": 0.7,\n      \"max_tokens\": 1500,\n      \"system_prompt\": \"Eres un asistente especializado en turismo de Asturias\"\n    },\n    \"teams_config\": {\n      \"webhook_url\": \"https://outlook.office.com/webhook/...\",\n      \"channel_name\": \"#customer-support\"\n    },\n    \"email_config\": {\n      \"from_email\": \"noreply@asturias.com\",\n      \"smtp_host\": \"smtp.gmail.com\",\n      \"smtp_port\": 587\n    },\n    \"fsm_config\": {\n      \"max_conversation_turns\": 50,\n      \"auto_handoff_enabled\": true\n    },\n    \"payment_config\": {\n      \"provider\": \"stripe\",\n      \"currency\": \"EUR\"\n    }\n  }\n}"
            },
            "description": "Crea un nuevo tenant con toda su configuración"
          },
          "response": [
            {
              "name": "Create Tenant Response",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Turismo Asturias\",\n  \"domain\": \"asturias.com\"\n}"
                },
                "url": {
                  "raw": "http://localhost:8003/api/tenants",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8003",
                  "path": ["api", "tenants"]
                }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"tenant-uuid-123\",\n    \"name\": \"Turismo Asturias\",\n    \"domain\": \"asturias.com\",\n    \"status\": \"active\",\n    \"created_at\": \"2026-04-11T10:00:00Z\",\n    \"config\": {...}\n  }\n}"
            }
          ]
        },
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/api/tenants?page=1&limit=20",
