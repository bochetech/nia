              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants", "{{tenant_id}}", "widget-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user-123\",\n  \"session_id\": \"{{session_id}}\",\n  \"expires_in\": 3600\n}"
            },
            "description": "Genera un token JWT para el widget de chat"
          }
        },
        {
          "name": "Suspend Tenant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/api/tenants/{{tenant_id}}/suspend",
              "host": ["{{base_url}}"],
              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants", "{{tenant_id}}", "suspend"]
            },
