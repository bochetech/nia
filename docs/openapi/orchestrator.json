{
    "openapi": "3.1.0",
    "info": {
        "title": "NIA Orchestrator",
        "description": "Central conversation orchestrator: intent detection, FSM routing, RAG, recommendations and handoff.",
        "version": "1.0.0"
    },
    "paths": {
        "/health/ready": {
            "get": {
                "tags": [
                    "ops"
                ],
                "summary": "Readiness",
                "operationId": "readiness_health_ready_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
        "/v1/chat": {
            "post": {
                "tags": [
                    "chat"
                ],
                "summary": "Send a message in a conversation session",
                "description": "Main chat endpoint. Authenticated with a widget JWT (`Authorization: Bearer <token>`).\n\nThe JWT is issued by the tenant-manager via `POST /api/tenants/{tenant_id}/widget-token`\nand encodes the `session_id` and `tenant_id` \u2014 no need to pass them in the body.",
                "operationId": "chat_v1_chat_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ChatRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/APIResponse_ChatResponse_"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ]
            }
        },
        "/v1/sessions/{session_id}/lead": {
            "post": {
                "tags": [
                    "chat"
                ],
                "summary": "Submit lead capture form",
                "description": "Submit the lead capture form for the current session.\nCalled by the widget after the user fills in their contact data.\nThe JWT session_id is used as the canonical session identity.",
                "operationId": "submit_lead_v1_sessions__session_id__lead_post",
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "session_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Session Id"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LeadSubmitRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/APIResponse_dict_"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/sessions/{session_id}": {
            "get": {
                "tags": [
                    "chat"
                ],
                "summary": "Get current session state",
                "description": "Returns the FSM state and metadata for the current session.",
                "operationId": "get_session_v1_sessions__session_id__get",
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "session_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Session Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/APIResponse_SessionStateResponse_"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "APIResponse_ChatResponse_": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/ChatResponse"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/ResponseMeta"
                    },
                    "_links": {
                        "additionalProperties": {
                            "$ref": "#/components/schemas/HATEOASLink"
                        },
                        "type": "object",
                        "title": " Links",
                        "default": {}
                    }
                },
                "type": "object",
                "required": [
                    "data"
                ],
                "title": "APIResponse[ChatResponse]"
            },
            "APIResponse_SessionStateResponse_": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/SessionStateResponse"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/ResponseMeta"
                    },
                    "_links": {
                        "additionalProperties": {
                            "$ref": "#/components/schemas/HATEOASLink"
                        },
                        "type": "object",
                        "title": " Links",
                        "default": {}
                    }
                },
                "type": "object",
                "required": [
                    "data"
                ],
                "title": "APIResponse[SessionStateResponse]"
            },
            "APIResponse_dict_": {
                "properties": {
                    "data": {
                        "type": "object",
                        "title": "Data"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/ResponseMeta"
                    },
                    "_links": {
                        "additionalProperties": {
                            "$ref": "#/components/schemas/HATEOASLink"
                        },
                        "type": "object",
                        "title": " Links",
                        "default": {}
                    }
                },
                "type": "object",
                "required": [
                    "data"
                ],
                "title": "APIResponse[dict]"
            },
            "ChatRequest": {
                "properties": {
                    "message": {
                        "type": "string",
                        "title": "Message"
                    }
                },
                "type": "object",
                "required": [
                    "message"
                ],
                "title": "ChatRequest",
                "example": {
                    "message": "\u00bfCu\u00e1l es el horario de la vi\u00f1a?"
                }
            },
            "ChatResponse": {
                "properties": {
                    "session_id": {
                        "type": "string",
                        "title": "Session Id"
                    },
                    "tenant_id": {
                        "type": "string",
                        "title": "Tenant Id"
                    },
                    "response": {
                        "type": "string",
                        "title": "Response"
                    },
                    "fsm_state": {
                        "type": "string",
                        "title": "Fsm State"
                    },
                    "show_lead_form": {
                        "type": "boolean",
                        "title": "Show Lead Form",
                        "default": false
                    },
                    "recommendations": {
                        "anyOf": [
                            {
                                "items": {},
                                "type": "array"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Recommendations"
                    },
                    "handoff_triggered": {
                        "type": "boolean",
                        "title": "Handoff Triggered",
                        "default": false
                    },
                    "checkout_url": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Checkout Url"
                    },
                    "tokens_used": {
                        "type": "integer",
                        "title": "Tokens Used",
                        "default": 0
                    }
                },
                "type": "object",
                "required": [
                    "session_id",
                    "tenant_id",
                    "response",
                    "fsm_state"
                ],
                "title": "ChatResponse"
            },
            "HATEOASLink": {
                "properties": {
                    "href": {
                        "type": "string",
                        "title": "Href"
                    },
                    "method": {
                        "type": "string",
                        "title": "Method",
                        "default": "GET"
                    },
                    "rel": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Rel"
                    }
                },
                "type": "object",
                "required": [
                    "href"
                ],
                "title": "HATEOASLink"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "LeadSubmitRequest": {
                "properties": {
                    "lead_data": {
                        "type": "object",
                        "title": "Lead Data"
                    },
                    "gdpr_consent": {
                        "type": "boolean",
                        "title": "Gdpr Consent",
                        "default": false
                    }
                },
                "type": "object",
                "required": [
                    "lead_data"
                ],
                "title": "LeadSubmitRequest",
                "example": {
                    "gdpr_consent": true,
                    "lead_data": {
                        "email": "maria@example.com",
                        "full_name": "Mar\u00eda Garc\u00eda"
                    }
                }
            },
            "ResponseMeta": {
                "properties": {
                    "request_id": {
                        "type": "string",
                        "title": "Request Id"
                    },
                    "timestamp": {
                        "type": "string",
                        "title": "Timestamp"
                    },
                    "version": {
                        "type": "string",
                        "title": "Version",
                        "default": "1"
                    }
                },
                "type": "object",
                "title": "ResponseMeta"
            },
            "SessionStateResponse": {
                "properties": {
                    "session_id": {
                        "type": "string",
                        "title": "Session Id"
                    },
                    "tenant_id": {
                        "type": "string",
                        "title": "Tenant Id"
                    },
                    "fsm_state": {
                        "type": "string",
                        "title": "Fsm State"
                    },
                    "messages_count": {
                        "type": "integer",
                        "title": "Messages Count"
                    },
                    "lead_captured": {
                        "type": "boolean",
                        "title": "Lead Captured"
                    },
                    "last_intent": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Last Intent"
                    },
                    "tokens_used": {
                        "type": "integer",
                        "title": "Tokens Used",
                        "default": 0
                    }
                },
                "type": "object",
                "required": [
                    "session_id",
                    "tenant_id",
                    "fsm_state",
                    "messages_count",
                    "lead_captured"
                ],
                "title": "SessionStateResponse"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        },
        "securitySchemes": {
            "HTTPBearer": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    }
}
