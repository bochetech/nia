                                "schema": {
                                    "$ref": "#/components/schemas/APIResponse_ChatResponse_"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/chat/stream": {
            "post": {
                "tags": [
                    "chat"
                ],
