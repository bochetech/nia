  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generar session_id único para cada request si no existe",
          "if (!pm.environment.get('session_id') || pm.environment.get('session_id') === '') {",
          "    pm.environment.set('session_id', pm.variables.replaceIn('{{$randomUUID}}'));",
          "}",
          "",
          "// Log de la request para debugging",
          "console.log('Request URL:', pm.request.url.toString());",
          "console.log('Session ID:', pm.environment.get('session_id'));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Tests automáticos para todas las responses",
          "pm.test('Status code is successful', function () {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
          "});",
          "",
          "pm.test('Response time is less than 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "// Test para responses JSON con estructura APIResponse",
          "if (pm.response.headers.get('Content-Type')?.includes('application/json')) {",
          "    pm.test('Response has valid JSON structure', function () {",
          "        const jsonData = pm.response.json();",
          "        pm.expect(jsonData).to.be.an('object');",
          "        ",
          "        // Para APIResponse standard",
          "        if (jsonData.hasOwnProperty('success')) {",
          "            pm.expect(jsonData.success).to.be.a('boolean');",
          "            if (jsonData.success) {",
          "                pm.expect(jsonData).to.have.property('data');",
          "            }",
          "        }",
          "    });",
          "}",
          "",
          "// Guardar datos importantes para requests posteriores",
          "if (pm.response.code === 201 || pm.response.code === 200) {",
          "    try {",
          "        const responseJson = pm.response.json();",
          "        ",
          "        // Guardar tenant_id si se crea un tenant",
          "        if (responseJson.data && responseJson.data.id && pm.request.url.path.includes('tenants')) {",
          "            pm.environment.set('created_tenant_id', responseJson.data.id);",
          "        }",
          "        ",
          "        // Guardar session_id de responses",
          "        if (responseJson.data && responseJson.data.session_id) {",
          "            pm.environment.set('session_id', responseJson.data.session_id);",
          "        }",
          "        ",
          "        // Guardar tokens de auth",
          "        if (responseJson.data && responseJson.data.token) {",
          "            pm.environment.set('auth_token', 'Bearer ' + responseJson.data.token);",
          "        }",
          "        ",
          "    } catch (e) {",
          "        console.log('Could not parse response JSON for data extraction');",
          "    }",
          "}"
        ]
      }
    }
  ]
