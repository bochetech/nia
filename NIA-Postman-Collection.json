          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/health",
              "host": ["{{base_url}}"],
              "port": "{{tenant_manager_port}}",
              "path": ["health"]
            },
            "description": "Verifica el estado de salud del tenant manager"
          }
        }
      ]
    },
