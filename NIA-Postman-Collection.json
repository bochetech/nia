              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Lista todos los tenants con paginación"
          }
        },
        {
          "name": "Get Tenant",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/api/tenants/{{tenant_id}}",
              "host": ["{{base_url}}"],
              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants", "{{tenant_id}}"]
            },
            "description": "Obtiene los detalles de un tenant específico"
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}:{{tenant_manager_port}}/api/tenants/{{tenant_id}}",
              "host": ["{{base_url}}"],
              "port": "{{tenant_manager_port}}",
              "path": ["api", "tenants", "{{tenant_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Turismo Asturias Premium\",\n  \"config\": {\n    \"ai_config\": {\n      \"temperature\": 0.8\n    }\n  }\n}"
